# Backend API base URL (no trailing slash)
# Dev: http://localhost:8000
# Production: https://<your-app>.up.railway.app
VITE_API_URL=http://localhost:8000

# Backend WebSocket URL
# Dev: ws://localhost:8000/ws
# Production: wss://<your-app>.up.railway.app/ws
VITE_WS_URL=ws://localhost:8000/ws

# Optional: Public-facing app URL for shareable invite links (no trailing slash)
# When set, invite links will be shown as full URLs (e.g. https://app.example.com/invite/CODE)
# When not set, only the invite code is shown and users paste it in the "Join via invite" dialog
# VITE_APP_URL=https://app.example.com
